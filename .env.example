# REFR Environment Variables
# Copy to .env and fill in values. App fails on startup if required vars are missing.

# ─── Required ────────────────────────────────────────────────────────────────

# Django secret key. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# PostgreSQL connection URL
DATABASE_URL=postgresql://your_user@localhost:5432/refr

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Set to True for local development (enables debug mode, allows all CORS/hosts)
DEBUG=True

# ─── Google Cloud / Vertex AI (for resume parsing) ───────────────────────────

# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_VERTEX_CREDENTIALS_JSON='{ "type": "service_account", ... }'
