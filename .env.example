# REFR Environment Variables
# Copy this file to .env and fill in the values

# ─── Django ──────────────────────────────────────────────────────────────────
# REQUIRED in production. If unset in dev, a key is auto-generated at
# backend/.secret_key (gitignored). Never commit a real key.
SECRET_KEY=

# Set to True only for local development
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection URL
DATABASE_URL=postgresql://your_user@localhost:5432/refr

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to True to allow all origins (dev only, NEVER in production)
CORS_ALLOW_ALL=True

# Comma-separated list of allowed origins (used when CORS_ALLOW_ALL=False)
# CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── Google Vertex AI (optional, for resume parsing) ─────────────────────────
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_LOCATION=
# GOOGLE_VERTEX_CREDENTIALS_JSON=
