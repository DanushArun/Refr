# REFR Environment Variables
# Copy to .env and fill in values.

# ─── Required ────────────────────────────────────────────────────────────────
SECRET_KEY=
DATABASE_URL=postgresql://your_user@localhost:5432/refr

# ─── Optional ────────────────────────────────────────────────────────────────
DEBUG=True

# ─── Google Cloud / Vertex AI ────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_VERTEX_CREDENTIALS_PATH=backend/gcp-credentials.json
