# REFR Environment Variables
# Copy to .env and fill in values. App fails on startup if required vars are missing.

# ─── Required ────────────────────────────────────────────────────────────────

# Django secret key. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# PostgreSQL connection URL
DATABASE_URL=postgresql://your_user@localhost:5432/refr

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Set to True for local development (enables debug mode, allows all CORS/hosts)
DEBUG=True

# Comma-separated. Only matters when DEBUG=False.
# ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Google Vertex AI (optional, for resume parsing) ─────────────────────────

# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_LOCATION=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
