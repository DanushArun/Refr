{
  "name": "refr",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=frontend",
    "shared:build": "npm run build --workspace=@refr/shared",
    "dev": "npm run frontend:dev",
    "typecheck": "tsc --noEmit --workspace=frontend",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
