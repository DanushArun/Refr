// REFR – Prisma schema
// Database: PostgreSQL via Supabase (AWS Mumbai / ap-south-1)
// All IDs are UUIDs generated by the database (gen_random_uuid()).
// Timestamps are stored as UTC and returned as ISO-8601 strings.
//
// Partitioning note: The messages and behavior_events tables grow unboundedly.
// Partition both by month from day one (manual DDL after migrate; Prisma does
// not support declarative partitioning yet — see docs/partitioning.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  seeker
  referrer
}

enum ReferralStatus {
  requested
  accepted
  submitted
  interviewing
  hired
  rejected
  withdrawn
  expired
}

enum ContentType {
  career_story
  company_intel
  referral_event
  milestone
  editorial
}

enum VerificationStatus {
  pending
  verified
  failed
  skipped
}

enum ModerationStatus {
  pending
  approved
  rejected
  removed
}

// ─── Core tables ──────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Supabase Auth UID — must match auth.users.id for RLS
  authId      String   @unique @map("auth_id")
  email       String   @unique
  phone       String?  @unique
  role        UserRole
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  seekerProfile    SeekerProfile?
  referrerProfile  ReferrerProfile?
  sentMessages     Message[]          @relation("MessageSender")
  behaviorEvents   BehaviorEvent[]
  moderationReviews ModerationQueue[] @relation("Reviewer")

  @@index([email])
  @@index([authId])
  @@map("users")
}

model Company {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @unique
  logoUrl            String?  @map("logo_url")
  // e.g. "51-200", "201-1000", "1001-5000", "5001+"
  employeeCountRange String?  @map("employee_count_range")
  // Used to auto-verify referrers (email domain matching)
  domain             String?  @unique
  createdAt          DateTime @default(now()) @map("created_at")

  referrerProfiles ReferrerProfile[]
  referrals        Referral[]
  contentCards     ContentCard[]

  @@index([domain])
  @@map("companies")
}

model SeekerProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  headline          String   @db.VarChar(120)
  // Full narrative assembled from guided prompts (may be AI-assisted via Claude)
  careerStory       String   @map("career_story") @db.Text
  skills            String[]
  yearsOfExperience Int      @map("years_of_experience")
  currentCompany    String?  @map("current_company")
  targetCompanies   String[] @map("target_companies")
  targetRoles       String[] @map("target_roles")
  resumeUrl         String?  @map("resume_url")
  isOpenToWork      Boolean  @default(true) @map("is_open_to_work")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[] @relation("SeekerReferrals")

  @@index([isOpenToWork])
  @@index([skills])
  @@map("seeker_profiles")
}

model ReferrerProfile {
  id                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String             @unique @map("user_id") @db.Uuid
  companyId                String             @map("company_id") @db.Uuid
  department               String
  jobTitle                 String             @map("job_title")
  yearsAtCompany           Int                @map("years_at_company")
  // Departments/roles this referrer can champion (e.g. ["Backend", "Platform"])
  canReferTo               String[]           @map("can_refer_to")
  // Kingmaker Score: 0-100, earned through successful referral outcomes
  kingmakerScore           Int                @default(0) @map("kingmaker_score")
  totalReferrals           Int                @default(0) @map("total_referrals")
  successfulHires          Int                @default(0) @map("successful_hires")
  verificationStatus       VerificationStatus @default(pending) @map("verification_status")
  isAnonymousPostingEnabled Boolean           @default(true) @map("is_anonymous_posting_enabled")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company    @relation(fields: [companyId], references: [id])
  referrals Referral[] @relation("ReferrerReferrals")

  @@index([companyId])
  @@index([kingmakerScore])
  @@index([verificationStatus])
  @@map("referrer_profiles")
}

// ─── Content & Feed ───────────────────────────────────────────────────────────

model ContentCard {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type          ContentType
  // Denormalised ranking score; re-computed by scheduled job every 15 min
  score         Float       @default(0)
  reactionCount Int         @default(0) @map("reaction_count")
  // All card-type-specific fields stored as JSONB for flexibility
  // Shape validated at the application layer (see content.types.ts)
  payload       Json
  // Author — nullable for system-generated cards (referral_event, milestone)
  authorId      String?     @map("author_id") @db.Uuid
  companyId     String?     @map("company_id") @db.Uuid
  // Soft delete: removed content is hidden but kept for audit
  isRemoved     Boolean     @default(false) @map("is_removed")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id])
  referrals       Referral[]       @relation("FeedCardReferrals")
  moderationItems ModerationQueue[]

  // Composite index supports cursor-based pagination by (score DESC, createdAt DESC)
  @@index([score(sort: Desc), createdAt(sort: Desc)])
  @@index([type])
  @@index([authorId])
  @@index([isRemoved])
  // Partition reminder: partition this table by month on createdAt in raw DDL
  @@map("content_cards")
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seekerId     String         @map("seeker_id") @db.Uuid
  referrerId   String         @map("referrer_id") @db.Uuid
  companyId    String         @map("company_id") @db.Uuid
  targetRole   String         @map("target_role") @db.VarChar(100)
  status       ReferralStatus @default(requested)
  // Rule-based match score at time of request (0-100)
  matchScore   Int            @default(0) @map("match_score")
  seekerNote   String?        @map("seeker_note") @db.VarChar(500)
  referrerNote String?        @map("referrer_note") @db.Text
  // Attribution: which content card triggered this referral request
  feedCardId   String?        @map("feed_card_id") @db.Uuid

  // State timestamps — set when entering each state, null until then
  requestedAt   DateTime  @default(now()) @map("requested_at")
  acceptedAt    DateTime? @map("accepted_at")
  submittedAt   DateTime? @map("submitted_at")
  interviewingAt DateTime? @map("interviewing_at")
  outcomeAt     DateTime? @map("outcome_at")

  seeker       SeekerProfile   @relation("SeekerReferrals", fields: [seekerId], references: [id])
  referrer     ReferrerProfile @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  company      Company         @relation(fields: [companyId], references: [id])
  feedCard     ContentCard?    @relation("FeedCardReferrals", fields: [feedCardId], references: [id])
  conversation Conversation?

  @@index([seekerId, status])
  @@index([referrerId, status])
  @@index([companyId])
  @@index([status, requestedAt])
  @@map("referrals")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referralId String   @unique @map("referral_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  referral Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  // Partition reminder: partition this table by month on createdAt in raw DDL
  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Behavior Events ──────────────────────────────────────────────────────────

model BehaviorEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(50)
  cardId         String?  @map("card_id") @db.Uuid
  cardType       String?  @map("card_type") @db.VarChar(50)
  positionInFeed Int?     @map("position_in_feed")
  durationMs     Int?     @map("duration_ms")
  action         String?  @db.VarChar(50)
  // Extra properties (device info, session id, etc.)
  payload        Json?
  timestamp      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Partition reminder: partition this table by month on timestamp in raw DDL
  @@index([userId, timestamp])
  @@index([cardId])
  @@index([eventType])
  @@map("behavior_events")
}

// ─── Moderation ───────────────────────────────────────────────────────────────

model ModerationQueue {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentCardId String           @map("content_card_id") @db.Uuid
  reason        String           @db.VarChar(500)
  status        ModerationStatus @default(pending)
  // Who filed the report (null = system auto-flag)
  reportedById  String?          @map("reported_by_id") @db.Uuid
  reviewedById  String?          @map("reviewed_by_id") @db.Uuid
  reviewedAt    DateTime?        @map("reviewed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  contentCard ContentCard @relation(fields: [contentCardId], references: [id])
  reviewedBy  User?       @relation("Reviewer", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([contentCardId])
  @@map("moderation_queue")
}
