# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# anon/public key (used to verify JWTs from client sessions)
SUPABASE_ANON_KEY=your-anon-key-here
# JWT secret from Supabase dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── Database (direct Postgres connection via Supabase) ───────────────────────
# Format: postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ─── Redis (Upstash serverless Redis) ────────────────────────────────────────
# From Upstash console → your database → REST API section
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# BullMQ needs a standard Redis connection (use Upstash with TLS)
REDIS_URL=rediss://default:your-redis-token@your-redis-url.upstash.io:6379

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret-here
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=noreply@refr.in

# ─── Firebase (push notifications) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── Claude API (resume parsing) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# ─── App Config ───────────────────────────────────────────────────────────────
# How many hours before a referral request expires with no response
REFERRAL_EXPIRY_HOURS=72
# Base URL for deep links in emails/notifications
APP_BASE_URL=https://app.refr.in
# Success fee in paise (100 paise = 1 INR); 22000 INR = 2200000 paise
HIRE_SUCCESS_FEE_PAISE=2200000
